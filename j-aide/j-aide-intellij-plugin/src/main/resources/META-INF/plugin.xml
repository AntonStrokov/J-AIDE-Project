<idea-plugin>
    <id>com.antonstrokov.jaide</id>
    <name>J-Aide</name>
    <vendor email="89173442264@mail.ru">Anton Strokov</vendor>

    <description>
        J-Aide plugin for explaining selected code using local AI backend.
    </description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup
                id="J-Aide Notifications"
                displayType="BALLOON"/>

        <toolWindow
                id="J-Aide"
                anchor="right"
                factoryClass="com.antonstrokov.jaide.plugin.ui.JaideToolWindowFactory"/>
    </extensions>

    <actions>
        <action
                id="J-Aide.ExplainSelectedCode"
                class="com.antonstrokov.jaide.plugin.ExplainSelectedCodeAction"
                text="J-Aide: Explain Selected Code"
                description="Explain selected code using J-Aide backend">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
        <action
                id="J-Aide.ImproveSelectedCode"
                class="com.antonstrokov.jaide.plugin.ImproveSelectedCodeAction"
                text="J-Aide: Improve Selected Code"
                description="Improve selected code using J-Aide backend">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
        <action
                id="J-Aide.ExplainRuntimeError"
                class="com.antonstrokov.jaide.plugin.ExplainRuntimeErrorAction"
                text="J-Aide: Explain Runtime Error"
                description="Explain runtime error, stack trace, or application log using J-Aide backend">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
<!--        <action-->
<!--                id="J-Aide.ApplyLastImprovement"-->
<!--                class="com.antonstrokov.jaide.plugin.ApplyLastImprovementAction"-->
<!--                text="J-Aide: Apply Last Improvement"-->
<!--                description="Replace selected code with the latest J-Aide improvement">-->
<!--            <add-to-group group-id="EditorPopupMenu" anchor="last"/>-->
<!--        </action>-->
    </actions>

</idea-plugin>